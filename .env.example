# Drak (legacy JSON-RPC) API token — for campaigns, ads, keywords, etc.
# Get it from Sklik web admin → Nastavení → API token
# https://www.sklik.cz/c/account/api/
SKLIK_API_TOKEN=your-drak-token-here

# Optional: Sklik /v1 (unified) refresh token — for Sklik Nákupy / Fénix.
# Get it from https://www.sklik.cz/ → API → generate refresh token.
# Without this, Fénix tools are not registered.
# SKLIK_FENIX_TOKEN=your-v1-refresh-token-here

# Optional overrides:
# SKLIK_ENDPOINT=https://api.sklik.cz/drak/json/v5
# SKLIK_FENIX_ENDPOINT=https://api.sklik.cz/v1
# SKLIK_REQUEST_TIMEOUT_S=30
# SKLIK_LOG_LEVEL=INFO
